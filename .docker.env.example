# Название Compose-проекта
COMPOSE_PROJECT_NAME=docker-mysql

# Версии
MYSQL_VERSION=8.0.21
ADMINER_VERSION=latest

# Имена контейнеров
MYSQL_CONTAINER=mysql
ADMINER_CONTAINER=adminer

# Порты хоста
MYSQL_PORT=3306
ADMINER_PORT=8081

# Данные и конфиги
MYSQL_DATA_DIR=./data/mysql
MYSQL_CONF_FILE=./conf/my.cnf
INITDB_DIR=./initdb

# Начальная учебная база
MYSQL_DATABASE=demo

# Локальные учебные credentials.
# Не используйте эти значения в публичном или production-окружении.
MYSQL_ROOT_PASSWORD=root
DB_USER=student
DB_PASSWORD=student

# Внешняя сеть при необходимости.
# EXTERNAL_NETWORK=external
