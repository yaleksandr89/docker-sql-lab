# Название Compose-проекта
COMPOSE_PROJECT_NAME=sql-lab

# Закреплённые версии СУБД и версия UI
MYSQL_VERSION=9.7.1
POSTGRES_VERSION=18.4
ADMINER_VERSION=5.4.2

# Имена контейнеров
MYSQL_CONTAINER=mysql
POSTGRES_CONTAINER=postgres
ADMINER_CONTAINER=adminer

# Порты хоста
MYSQL_PORT=3306
POSTGRES_PORT=5432
ADMINER_PORT=8081

# Данные, конфигурация, обязательный init и опциональные samples
MYSQL_DATA_DIR=./data/mysql
POSTGRES_DATA_DIR=./data/postgres
MYSQL_CONF_FILE=./conf/mysql/my.cnf
MYSQL_INITDB_DIR=./initdb/mysql
POSTGRES_INITDB_DIR=./initdb/postgres
MYSQL_SAMPLES_DIR=./samples/mysql
POSTGRES_SAMPLES_DIR=./samples/postgres

# Обязательные учебные базы
MYSQL_DATABASE=demo
POSTGRES_DATABASE=demo

# Локальные административные credentials.
# Не используйте эти значения в публичном или production-окружении.
MYSQL_ROOT_PASSWORD=root
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres

# Общие локальные credentials учебного пользователя обеих СУБД.
DB_USER=student
DB_PASSWORD=student

# Внешняя сеть при необходимости.
# EXTERNAL_NETWORK=external
