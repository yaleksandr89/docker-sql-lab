[mysqld]

# Кодировка
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci

# Предсказуемое и близкое к стандартному SQL поведение
sql_mode = ONLY_FULL_GROUP_BY,STRICT_ALL_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# Единое время учебного стенда
default_time_zone = '+03:00'

# Не выполнять DNS lookup для клиентов
skip-name-resolve = ON

# Диагностика медленных запросов — включать временно
# slow_query_log = ON
# long_query_time = 0.5
# log_queries_not_using_indexes = OFF

# Только когда MySQL работает один и контейнеру явно выделены ресурсы
# innodb_dedicated_server = ON

# Увеличивать только при реальной необходимости
# max_connections = 200

# Увеличение влияет на потребление памяти соединениями
# tmp_table_size = 64M
# max_heap_table_size = 64M
