# Этот файл не подключается к Compose автоматически.
# Значения являются учебными примерами, а не универсальной оптимизацией.
# Подходящие значения зависят от доступных ресурсов и характера нагрузки.

# Для выделенного PostgreSQL-сервера с известным объёмом памяти:
# shared_buffers = '256MB'

# Применяется к отдельным sort/hash операциям каждого запроса:
# work_mem = '8MB'

# Используется VACUUM, CREATE INDEX и другими maintenance-операциями:
# maintenance_work_mem = '64MB'

# Временная диагностика запросов дольше 500 мс:
# log_min_duration_statement = '500ms'
