-- Шаблон добавления новой учебной базы.
--
-- Файл заканчивается на .sql.example, поэтому MySQL entrypoint
-- не выполняет его автоматически.
--
-- ============================================================================
-- Вариант 1. Добавить базу при следующей чистой инициализации
-- ============================================================================
--
-- Скопируйте шаблон:
--
--   cp initdb/mysql/030_training_database.sql.example initdb/mysql/030_shop.sql
--
-- Замените во всём файле:
--
--   training_database -> shop
--
-- Затем выполните полный сброс:
--
--   make reinit-mysql CONFIRM=1
--
-- При чистой инициализации порядок будет таким:
--
--   001_demo.sql
--   030_shop.sql
--   050_load_optional_samples.sh
--   090_grant_training_access.sh
--   099_check_training_access.sh
--
-- Grant-скрипт обнаружит новую пользовательскую базу shop и выдаст
-- учебному пользователю доступ к ней во время чистой инициализации.
--
-- ============================================================================
-- Вариант 2. Добавить базу в уже работающий MySQL без удаления данных
-- ============================================================================
--
-- Административно создайте новую базу отдельно, затем примените grants:
--
--   make mysql-grants
--
-- Подготовьте доверенный plain SQL-файл со схемой и данными для уже созданной
-- базы shop. В нём не должно быть CREATE DATABASE и USE.
--
-- Выполните импорт:
--
--   make mysql-import FILE=/path/to/shop.sql DATABASE=shop
--
-- mysql-import требует FILE и DATABASE, выполняет импорт от имени DB_USER,
-- не создаёт базу и не выдаёт grants, а после импорта запускает проверку
-- доступа учебного пользователя.
--
-- ============================================================================
-- Вариант 3. Добавить сторонний SQL dump
-- ============================================================================
--
-- Сторонний dump нужно привести к форме schema/data-only без database-level
-- directives (CREATE DATABASE и USE), а административное создание или
-- восстановление базы выполнить отдельно от mysql-import.
--
-- mysql-import предназначен для доверенного plain SQL внутри уже
-- существующей базы; он не является sandbox для недоверенного SQL.
--
-- Например, если dump содержит:
--
--   CREATE DATABASE ...
--   USE ...
--
-- удалите эти директивы перед импортом.
--
-- ============================================================================
-- Вариант 4. Разделить схему и данные на несколько файлов
-- ============================================================================
--
-- Можно создать:
--
--   initdb/mysql/030_shop_schema.sql
--   initdb/mysql/031_shop_data.sql
--
-- Главное требование: оба файла должны выполняться раньше
-- 050_load_optional_samples.sh, 090_grant_training_access.sh и
-- 099_check_training_access.sh.
--
-- ============================================================================
-- Пример содержимого учебной базы
-- ============================================================================

CREATE DATABASE IF NOT EXISTS `training_database`
    CHARACTER SET utf8mb4
    COLLATE utf8mb4_0900_ai_ci;

USE `training_database`;

CREATE TABLE IF NOT EXISTS example_categories
(
    id   BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL UNIQUE
) ENGINE = InnoDB;

CREATE TABLE IF NOT EXISTS example_items
(
    id          BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    category_id BIGINT UNSIGNED NOT NULL,
    name        VARCHAR(255) NOT NULL,
    price       DECIMAL(10, 2) NOT NULL DEFAULT 0.00,
    created_at  TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_example_items_category
        FOREIGN KEY (category_id)
        REFERENCES example_categories (id)
) ENGINE = InnoDB;

INSERT IGNORE INTO example_categories (id, name)
VALUES (1, 'Books'),
       (2, 'Electronics');

INSERT IGNORE INTO example_items (id, category_id, name, price)
VALUES (1, 1, 'SQL Training Book', 19.90),
       (2, 2, 'Mechanical Keyboard', 79.90);
